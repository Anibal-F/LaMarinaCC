# Frontend via same-origin proxy
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:8010

# Backend local
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/lamarinacc
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# Local db tools
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lamarinacc
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Optional: WhatsApp Cloud API template sending
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_RECEPCION=recepcion_automovil
WHATSAPP_TEMPLATE_LANGUAGE=es
