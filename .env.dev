# Frontend via same-origin proxy
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:8010

# Backend local
# Para Docker: usar 'db'. Para local/RPA: usar 'localhost:5436'
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5436/lamarinacc
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# Local db tools
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lamarinacc
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin
