# Frontend via same-origin proxy
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:8010

# Backend local
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/lamarinacc
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# Local db tools
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lamarinacc
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Optional: WhatsApp Cloud API template sending
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_RECEPCION=recepcion_automovil
WHATSAPP_TEMPLATE_LANGUAGE=es
WHATSAPP_PDF_PUBLIC_BASE_URL=http://localhost:8010
WHATSAPP_WEBHOOK_VERIFY_TOKEN=local_verify_token
WHATSAPP_AUTO_REPLY_ENABLED=true
WHATSAPP_AUTO_REPLY_COOLDOWN_MINUTES=120
WHATSAPP_AUTO_REPLY_UBICACION=Estamos en Circunvalacion Playas #31, El Toreo, 82120, Mazatlan, Sinaloa.
WHATSAPP_AUTO_REPLY_HORARIO=Nuestro horario es de lunes a viernes de 8:00 a 18:00 y sabados de 9:00 a 14:00.
WHATSAPP_AUTO_REPLY_DUDA=Con gusto te apoyamos. Cuentanos tu duda y un asesor te respondera a la brevedad.
WHATSAPP_AUTO_REPLY_DEFAULT=Gracias por tu mensaje. En breve un asesor de La Marina Collision Center te atendera.
